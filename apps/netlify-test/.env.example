# -----------------------------------------------------------------------
# ecollect SDK - Test Console Environment Variables
#
# IMPORTANT: Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it is already in .gitignore.
#
# These variables are SERVER-SIDE ONLY (Netlify Functions).
# They are NOT prefixed with VITE_ on purpose — Vite would otherwise
# embed them into the browser JavaScript bundle, exposing them publicly.
# -----------------------------------------------------------------------

# Your ecollect API Key (from the merchant dashboard)
ECOLLECT_API_KEY=your_test_api_key_here

# Your merchant entity code
ECOLLECT_ENTITY_CODE=50039

# Environment: "test" uses test1.e-collect.com (no real charges)
#              "prod" uses www.e-collect.com (real transactions)
ECOLLECT_ENVIRONMENT=test
