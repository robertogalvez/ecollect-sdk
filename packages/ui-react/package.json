{
  "name": "@ecollect/ui-react",
  "version": "0.1.0",
  "description": "React card form components for ecollect — 3 themes, fully configurable",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "test": "node --experimental-vm-modules ../../node_modules/.bin/jest"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "dependencies": {
    "@ecollect/ui-core": "*"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "typescript": "^5.4.0"
  }
}
